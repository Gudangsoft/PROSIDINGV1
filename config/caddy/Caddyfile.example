# Reference Caddy config for the multi-tenant SaaS deployment (VPS/cloud).
# Not auto-loaded by Laravel — copy to /etc/caddy/Caddyfile on the server
# and adjust the placeholders below.
#
# Replace:
#   app.your-saas-domain.com   -> your actual central domain
#   /path/to/PROSIDINGV1/public -> absolute path to this app's public/ dir

# ── Central app (SaaS marketing site, tenant signup, super-admin) ──
app.your-saas-domain.com {
    root * /path/to/PROSIDINGV1/public
    php_fastcgi unix//run/php/php8.3-fpm.sock
    file_server
    encode gzip
}

# ── Tenant custom domains — On-Demand TLS ──
# Any domain not explicitly listed above falls here. Caddy asks our app
# whether it should issue a cert for a given domain before doing so; only
# verified tenant domains (or the central domain) get a "200 ok" back.
:443 {
    tls {
        on_demand
    }

    root * /path/to/PROSIDINGV1/public
    php_fastcgi unix//run/php/php8.3-fpm.sock
    file_server
    encode gzip
}

# Global on-demand TLS policy — points at the "ask" endpoint we built in
# routes/central.php (App\Models\Domain::verified() gate).
{
    on_demand_tls {
        ask https://app.your-saas-domain.com/internal/domain-check
        interval 2m
        burst 10
    }
}
