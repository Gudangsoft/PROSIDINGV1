# ======================================
# SECURITY CONFIGURATION GUIDE
# ======================================
# Panduan konfigurasi keamanan untuk production

# --- BASIC SECURITY ---
# IMPORTANT: Set to false in production!
APP_DEBUG=false
APP_ENV=production

# --- SESSION SECURITY ---
# Enable secure cookies (HTTPS only)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=true

# --- RATE LIMITING ---
# Sudah dikonfigurasi di RateLimitServiceProvider
# Tidak perlu konfigurasi tambahan di .env

# --- SECURITY HEADERS ---
# Sudah dikonfigurasi di SecurityHeaders middleware
# Tidak perlu konfigurasi tambahan di .env

# --- FILE UPLOAD SECURITY ---
# Maximum file sizes (in KB) - dikonfigurasi di FileUploadValidator
# PAPER: 10MB (10240 KB)
# IMAGE: 5MB (5120 KB)
# PAYMENT: 2MB (2048 KB)
# CV: 5MB (5120 KB)
# DELIVERABLE: 20MB (20480 KB)

# --- ANTI-MALWARE (config/security.php) ---
# Built-in static scanner (magic bytes, PDF active-content, Office macros,
# embedded executables, EICAR) runs on every upload with no setup needed.
# Optionally layer a real ClamAV scan on top if the server has it installed:
CLAMAV_ENABLED=false
CLAMAV_BINARY=clamscan
CLAMAV_TIMEOUT=15

# --- ANTI-SPAM (config/security.php) ---
# Tuning for the NoSpamContent rule and the honeypot time-trap on public forms
SPAM_MAX_LINKS=3
SPAM_HONEYPOT_MIN_SECONDS=2

# --- LOGGING & MONITORING ---
# Activity logging sudah aktif melalui ActivityLogger middleware
# Log file location: storage/logs/laravel.log

# --- BACKUP (Optional - Recommended) ---
# Gunakan package seperti spatie/laravel-backup
# BACKUP_DISK=s3
# BACKUP_NOTIFICATION_EMAIL=admin@example.com

# --- ADDITIONAL SECURITY (Optional) ---
# Two-Factor Authentication (Fortify)
# Sudah tersedia, aktifkan di user settings

# Email Verification (Optional)
# Uncomment di config/fortify.php:
# Features::emailVerification(),

# Trusted Proxies (jika menggunakan load balancer)
# TRUSTED_PROXIES=*

# ======================================
# CHECKLIST SECURITY UNTUK PRODUCTION
# ======================================
# [ ] Set APP_DEBUG=false
# [ ] Set APP_ENV=production
# [ ] Set SESSION_SECURE_COOKIE=true
# [ ] Gunakan HTTPS
# [ ] Update MAIL_* dengan kredensial yang benar
# [ ] Backup database secara berkala
# [ ] Monitor log file secara rutin
# [ ] Update dependencies secara berkala
# [ ] Implement IP whitelist untuk admin (optional)
# [ ] Enable two-factor authentication untuk admin
# [ ] Setup firewall (UFW/iptables)
# [ ] Gunakan strong database password
# [ ] Restrict database access ke localhost only

# ======================================
# SAMPLE PRODUCTION .env
# ======================================

APP_NAME="Prosiding SINACON"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://prosiding.example.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prosiding_production
DB_USERNAME=prosiding_user
DB_PASSWORD=SECURE_DATABASE_PASSWORD_HERE

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# No Redis on shared/cPanel hosting? Use QUEUE_CONNECTION=database and
# CACHE_STORE=database instead — both work with just MySQL, no extra service.
# Either way, a worker must run continuously: `php artisan queue:work`
# (via Supervisor), or on shared hosting without persistent processes, a
# cron entry every minute: `php artisan queue:work --stop-when-empty`.
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=SECURE_REDIS_PASSWORD
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-app-password-here"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@prosiding.example.com
MAIL_FROM_NAME="${APP_NAME}"
